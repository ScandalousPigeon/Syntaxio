<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.UI.cab302_project.controller.ChallengeBrowserController"
      style="-fx-background-color: #1a1a2e;">

    <!-- Top Bar -->
    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-background-color: #16213e;">
        <Button text="← Dashboard" onAction="#onBackToDashboard"
                style="-fx-background-color: transparent; -fx-text-fill: #4ecdc4; -fx-font-size: 14px;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Text text="📚 Challenge Browser" style="-fx-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Filters Bar -->
    <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #0f0f1a;">
        <HBox spacing="15">
            <TextField fx:id="searchField" promptText="🔍 Search challenges..." HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #1a1a2e; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 8;"/>
            <ComboBox fx:id="difficultyFilter" style="-fx-background-color: #1a1a2e; -fx-text-fill: white;"/>
            <ComboBox fx:id="statusFilter" style="-fx-background-color: #1a1a2e; -fx-text-fill: white;"/>
        </HBox>
        <Label fx:id="resultsCountLabel" text="Loading..." style="-fx-text-fill: #4ecdc4; -fx-font-size: 12px;"/>
    </VBox>

    <!-- Challenges Grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #1a1a2e; -fx-background: #1a1a2e;">
        <VBox spacing="15" style="-fx-padding: 15;">
            <Label fx:id="loadingLabel" text="Loading challenges..." 
                   style="-fx-text-fill: #4ecdc4; -fx-font-size: 14px;" visible="false"/>
            <FlowPane fx:id="challengesContainer" hgap="15" vgap="15"/>
        </VBox>
    </ScrollPane>
</VBox>