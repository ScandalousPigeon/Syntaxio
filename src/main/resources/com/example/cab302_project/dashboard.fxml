<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.UI.cab302_project.controller.DashboardController"
      style="-fx-background-color: #1a1a2e;">

    <!-- Top Bar -->
    <HBox alignment="CENTER_LEFT" style="-fx-padding: 20; -fx-background-color: #16213e;">
        <VBox>
            <Text text="CodeBuddy Dashboard" style="-fx-fill: #4ecdc4; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label fx:id="welcomeLabel" style="-fx-text-fill: #c8d6e5; -fx-font-size: 14px;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Logout" onAction="#onLogout"
                style="-fx-background-color: transparent; -fx-border-color: #e74c3c; -fx-border-radius: 5; -fx-text-fill: #e74c3c; -fx-padding: 5 15;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #1a1a2e; -fx-background: #1a1a2e;">
        <VBox spacing="20" style="-fx-padding: 20;">
            
            <!-- User Profile Card -->
            <HBox spacing="20" style="-fx-background-color: #16213e; -fx-background-radius: 10; -fx-padding: 20;">
                <VBox alignment="CENTER" spacing="5">
                    <Text text="👤" style="-fx-font-size: 48px;"/>
                    <Label fx:id="usernameLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="joinDateLabel" style="-fx-text-fill: #c8d6e5; -fx-font-size: 11px;"/>
                </VBox>
                
                <Separator orientation="VERTICAL" style="-fx-background-color: #4ecdc4;"/>
                
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label fx:id="statsLabel" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                    <Label fx:id="hintsUsedLabel" style="-fx-text-fill: #f9ca24; -fx-font-size: 12px;"/>
                    <Label fx:id="completionRateLabel" style="-fx-text-fill: #2ecc71; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>
            
            <!-- Progress Bar -->
            <VBox spacing="5" style="-fx-background-color: #16213e; -fx-background-radius: 10; -fx-padding: 15;">
                <Text text="🎯 Overall Progress" style="-fx-fill: #4ecdc4; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <ProgressBar fx:id="overallProgressBar" progress="0" style="-fx-accent: #2ecc71;" prefWidth="Infinity"/>
                <Label fx:id="progressPercentageLabel" text="0%" style="-fx-text-fill: white; -fx-font-size: 12px;"/>
            </VBox>
            
            <!-- Charts Row -->
            <HBox spacing="20">
                <!-- Pie Chart -->
                <VBox style="-fx-background-color: #16213e; -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                    <PieChart fx:id="progressChart" prefHeight="250" prefWidth="250"/>
                </VBox>
                
                <!-- Bar Chart -->
                <VBox style="-fx-background-color: #16213e; -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                    <BarChart fx:id="activityChart" prefHeight="250">
                        <xAxis>
                            <CategoryAxis fx:id="xAxis"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis fx:id="yAxis"/>
                        </yAxis>
                    </BarChart>
                </VBox>
            </HBox>
            
            <!-- Recent Activity & Quick Actions Row -->
            <HBox spacing="20">
                <!-- Recent Activity -->
                <VBox spacing="10" style="-fx-background-color: #16213e; -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                    <Text text="📋 Recent Activity" style="-fx-fill: #4ecdc4; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <ScrollPane fitToWidth="true" prefHeight="200" style="-fx-background-color: transparent;">
                        <VBox fx:id="recentActivityContainer" spacing="8"/>
                    </ScrollPane>
                </VBox>
                
                <!-- Quick Actions -->
                <VBox spacing="10" style="-fx-background-color: #16213e; -fx-background-radius: 10; -fx-padding: 15;" prefWidth="200">
                    <Text text="⚡ Quick Actions" style="-fx-fill: #4ecdc4; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <VBox fx:id="quickActionsContainer" spacing="10"/>
                </VBox>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>