<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.syntaxio.ui.controller.CodingChallengeController">
   <children>
      <BorderPane layoutX="68.0" layoutY="117.0" minHeight="900.0" minWidth="1200.0" prefHeight="900.0" prefWidth="1200.0" styleClass="background-layer" stylesheets="@css/base.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox prefHeight="100.0" prefWidth="200.0" styleClass="topbar" stylesheets="@css/coding-challenge.css" BorderPane.alignment="CENTER">
               <children>
                  <Button fx:id="backButton" mnemonicParsing="false" onAction="#onBack" styleClass="back-button" stylesheets="@css/coding-challenge.css" text="Back" />
                  <VBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="401.0">
                     <children>
                        <Label fx:id="titleLabel" text="Puzzle Name" textFill="WHITE">
                           <font>
                              <Font size="15.0" />
                           </font>
                        </Label>
                        <Label fx:id="difficultyLabel" text="Difficulty" textFill="RED" />
                     </children>
                  </VBox>
                  <Region prefHeight="70.0" prefWidth="356.0" />
                  <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="366.0" spacing="10.0">
                     <children>
                        <ProgressIndicator fx:id="loadingIndicator" prefHeight="28.0" prefWidth="28.0" visible="false" />
                        <Label fx:id="timeIndicator" prefWidth="62.0" styleClass="timer-box" stylesheets="@css/coding-challenge.css" text="Time" textFill="WHITE" />
                        <Button fx:id="runButton" mnemonicParsing="false" onAction="#onRun" prefHeight="32.0" prefWidth="64.0" styleClass="run-button" stylesheets="@css/coding-challenge.css" text="Run" />
                        <Button fx:id="submitButton" mnemonicParsing="false" onAction="#onSubmit" prefHeight="32.0" prefWidth="117.0" styleClass="submit-button" stylesheets="@css/coding-challenge.css" text="Submit" />
                     </children>
                  </HBox>
               </children></HBox>
         </top>
         <center>
            <HBox prefHeight="100.0" prefWidth="200.0" spacing="10.0" BorderPane.alignment="CENTER">
               <children>
                  <VBox prefHeight="828.0" prefWidth="600.0" styleClass="card" stylesheets="@css/coding-challenge.css">
                     <children>
                        <HBox fx:id="descriptionTabs" prefHeight="47.0" prefWidth="583.0" styleClass="tab-bar" stylesheets="@css/coding-challenge.css">
                           <children>
                              <ToggleButton fx:id="descriptionTab" mnemonicParsing="false" styleClass="tab-button" stylesheets="@css/coding-challenge.css" text="Description" />
                              <ToggleButton fx:id="aiAssistantTab" mnemonicParsing="false" styleClass="tab-button" stylesheets="@css/coding-challenge.css" text="AI Assistant" />
                           </children>
                        </HBox>
                        <TextArea fx:id="descriptionArea" editable="false" prefHeight="705.0" prefWidth="543.0" styleClass="code-area" stylesheets="@css/coding-challenge.css" wrapText="true">
                           <VBox.margin>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </VBox.margin>
                        </TextArea>
                     </children>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </VBox>
                  <VBox prefHeight="828.0" prefWidth="600.0" spacing="10.0">
                     <children>
                        <VBox prefHeight="414.0" prefWidth="590.0" styleClass="card" stylesheets="@css/coding-challenge.css">
                           <children>
                              <HBox prefHeight="100.0" prefWidth="200.0" styleClass="tab-bar" stylesheets="@css/coding-challenge.css">
                                 <children>
                                    <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Code Editor" />
                                 </children>
                              </HBox>
                              <TextArea fx:id="codeEditor" prefHeight="271.0" prefWidth="583.0" styleClass="code-area" stylesheets="@css/coding-challenge.css" VBox.vgrow="ALWAYS" />
                           </children>
                        </VBox>
                        <VBox prefHeight="414.0" prefWidth="100.0" styleClass="card" stylesheets="@css/coding-challenge.css">
                           <children>
                              <HBox prefHeight="100.0" prefWidth="200.0" styleClass="tab-bar" stylesheets="@css/coding-challenge.css">
                                 <children>
                                    <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Test Results" />
                                 </children>
                              </HBox>
                              <TextArea fx:id="outputArea" editable="false" prefHeight="120.0" prefWidth="583.0" styleClass="code-area" stylesheets="@css/coding-challenge.css" wrapText="true" />
                              <VBox fx:id="testResultsContainer" prefHeight="220.0" prefWidth="583.0" spacing="8.0" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </children>
               <BorderPane.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </BorderPane.margin>
            </HBox>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
